{
  "host": "localhost",
  "port": 3030,
  "public": "./public/",
  "origins": [
    "http://localhost:3000",
    "http://localhost:3030",
    "http://127.0.0.1:3000",
    "http://127.0.0.1:3030"
  ],
  "paginate": {
    "default": 10,
    "max": 50
  },
  "sqlite": {
    "client": "sqlite3",
    "connection": {
      "filename": "./feathers-auth-app.sqlite"
    },
    "useNullAsDefault": true
  },
  "authentication": {
    "entity": "user",
    "service": "users",
    "secret": "your-secret",
    "authStrategies": [
      "jwt",
      "local",
      "google",
      "github",
      "linkedin",
      "twitter2",
      "facebook"
    ],
    "jwtOptions": {
      "header": {
        "typ": "access"
      },
      "audience": "https://yourdomain.com",
      "issuer": "feathers",
      "algorithm": "HS256",
      "expiresIn": "1d"
    },
    "local": {
      "usernameField": "email",
      "passwordField": "password"
    },
    "oauth": {
      "redirect": "http://localhost:3000",
      "google": {
        "key": "your-google-client-id",
        "secret": "your-google-client-secret",
        "scope": [
          "profile",
          "email"
        ]
      },
      "github": {
        "key": "your-github-client-id",
        "secret": "your-github-client-secret",
        "scope": [
          "user:email"
        ],
        "custom_params": {
          "prompt": "select_account"
        }
      },
      "linkedin": {
        "key": "your-linkedin-client-id",
        "secret": "your-linkedin-client-secret",
        "scope": [
          "openid",
          "profile",
          "email"
        ],
        "callbackURL": "http://localhost:3030/oauth/linkedin/callback",
        "profile_url": "https://api.linkedin.com/v2/userinfo",
        "response": [
          "tokens",
          "profile"
        ]
      },
      "twitter2": {
        "key": "your-twitter-client-id",
        "secret": "your-twitter-client-secret",
        "state": true,
        "pkce": true,
        "scope": [
          "tweet.read",
          "users.read"
        ],
        "profile_url": "https://api.twitter.com/2/users/me?user.fields=id,name,username,profile_image_url",
        "redirect_uri": "http://127.0.0.1:3030/oauth/twitter2/callback"
      },
      "facebook": {
        "key": "your-facebook-client-id",
        "secret": "your-facebook-client-secret",
        "scope": [
          "email",
          "public_profile"
        ],
        "redirect_uri": "http://localhost:3030/oauth/facebook/callback",
        "profile_url": "https://graph.facebook.com/me?fields=id,name,email,picture"
      }
    }
  },
  "groq": {
    "apiKey": "your-groq-api-key"
  }
}
